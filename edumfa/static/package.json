{
  "name": "edumfa-ui",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "dependencies": {
    "@lingui/core": "^6.3.0",
    "@lingui/react": "^6.3.0",
    "@tanstack/react-query": "^5.101.0",
    "angular": "1.8.3",
    "angular-gettext": "2.4.2",
    "angular-hotkeys": "1.7.0",
    "angular-inform": "0.0.19",
    "angular-sanitize": "1.8.3",
    "angular-ui-bootstrap": "2.5.6",
    "angular-ui-router": "1.0.30",
    "bootstrap": "3.4.1",
    "isteven-angular-multiselect": "4.0.0",
    "jquery": "3.7.1",
    "ng-file-upload": "12.2.13",
    "ng-idle": "1.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.17.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lingui/babel-plugin-lingui-macro": "^6.3.0",
    "@lingui/cli": "^6.3.0",
    "@lingui/vite-plugin": "^6.3.0",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "grunt-angular-gettext": "2.5.3",
    "grunt-cli": "1.5.0",
    "grunt-init": "0.3.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "react:dev": "vite --host 127.0.0.1",
    "react:build": "bun run intl:compile && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint react-src vite.config.mts playwright.config.ts --max-warnings=0",
    "format:check": "prettier --check \"react-src/**/*.{ts,tsx,css,md}\" \"*.{mts,mjs,cjs,json}\"",
    "intl:compile": "lingui compile --typescript",
    "intl:extract": "lingui extract --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "translate": "grunt nggettext_extract && for language in translations/*.po; do msgmerge -U --backup=off $language translations/template.pot; done && grunt nggettext_compile"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edumfa/edumfa.git"
  },
  "keywords": [],
